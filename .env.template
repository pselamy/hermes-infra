# Hermes Infrastructure Environment
# Copy to .env and fill in real values

# OpenRouter API key for LLM access
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# Hermes agent config path (mounted into container)
HERMES_CONFIG_PATH=/etc/hermes/hermes.yaml

# Telegram bot integration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_ALLOWED_USERS=YOUR_TELEGRAM_USER_ID_HERE

# Allow all users without allowlist (set to false in production)
GATEWAY_ALLOW_ALL_USERS=true
